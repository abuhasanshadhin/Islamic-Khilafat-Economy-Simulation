# Example environment for the backend service
# Use this as a template and copy to .env before running in production or locally.

# Database URL for the backend service. When running in Docker, use the service name `db` and port 3306.
# Example (inside Docker network):
DATABASE_URL="mysql://baitul:baitulpass@db:3306/baitulmal"
# If you need to connect from the host machine (e.g. for local tools), the compose maps to host port 3307:
# mysql -u baitul -p -h 127.0.0.1 -P 3307

JWT_SECRET=change-me
PORT=3000

# Zakat configuration
ZAKAT_NISAB_MG=85000
# Interval in milliseconds for zakat worker. Default 24h (86400000). Set smaller for testing.
ZAKAT_INTERVAL_MS=86400000

# High value threshold (mg) for emitting market pulse events
HIGH_VALUE_THRESHOLD_MG=10000
