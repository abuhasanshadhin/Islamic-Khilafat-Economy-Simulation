generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserRole {
  USER
  SHURA
  KHALIFA
}

enum TransactionType {
  GRANT
  TRANSFER
  TRADE
  ZAKAT
}

enum Resource {
  GOLD
  OIL
  GAS
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  email String @unique
  password String
  goldBalance BigInt @default(0)
  reputationScore Int @default(0)
  isZakatEligible Boolean @default(false)
  role UserRole @default(USER)
  sentTransactions Transaction[] @relation("sentTransactions")
  receivedTransactions Transaction[] @relation("receivedTransactions")
  products Product[]
  stocksOwned Stock[]
  shareHoldings ShareOwnership[]
  reportsMade Report[] @relation("reportsMade")
  reportsAgainst Report[] @relation("reportsAgainst")
}

model BaitulMal {
  id Int @id @default(autoincrement())
  goldReserve BigInt @default(0)
  oilReserve Float @default(0.0)
  gasReserve Float @default(0.0)
  totalZakatCollected BigInt @default(0)
  miningLogs MiningLog[]
}

model Product {
  id Int @id @default(autoincrement())
  name String
  description String?
  price BigInt
  stock Int @default(0)
  ownerId Int
  owner User @relation(fields: [ownerId], references: [id])
}

model MiningLog {
  id Int @id @default(autoincrement())
  baitulMalId Int
  baitulMal BaitulMal @relation(fields: [baitulMalId], references: [id])
  goldExtracted BigInt @default(0)
  oilExtracted Float @default(0.0)
  gasExtracted Float @default(0.0)
  createdAt DateTime @default(now())
}

model Report {
  id Int @id @default(autoincrement())
  reporterId Int
  accusedId Int
  reporter User @relation("reportsMade", fields: [reporterId], references: [id])
  accused User @relation("reportsAgainst", fields: [accusedId], references: [id])
  reason String
  status String @default("OPEN")
  createdAt DateTime @default(now())
}

model Transaction {
  id Int @id @default(autoincrement())
  senderId Int?
  receiverId Int?
  sender User? @relation("sentTransactions", fields: [senderId], references: [id])
  receiver User? @relation("receivedTransactions", fields: [receiverId], references: [id])
  amount BigInt
  type TransactionType
  timestamp DateTime @default(now())
}

model ResourcePrice {
  id Int @id @default(autoincrement())
  resource Resource @unique
  priceInGoldMg Float
  updatedAt DateTime @updatedAt
}

model Stock {
  id Int @id @default(autoincrement())
  name String
  ownerId Int
  owner User @relation(fields: [ownerId], references: [id])
  totalShares Int
  availableShares Int
  sharePrice BigInt
  isPublic Boolean @default(false)
  listedAt DateTime?
  holdings ShareOwnership[]
}

model ShareOwnership {
  id Int @id @default(autoincrement())
  stockId Int
  stock Stock @relation(fields: [stockId], references: [id])
  userId Int
  user User @relation(fields: [userId], references: [id])
  shares Int
  @@unique([stockId, userId])
}
